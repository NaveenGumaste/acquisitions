# Server configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Application secrets
JWT_SECRET=<jwt_secret_here>
ARCJET_KEY=<arcjet_key_here>

# Database configuration
DATABASE_URL=<db connection string here>

# Neon Local toggle (set true for Neon Local proxy usage)
NEON_LOCAL=false
# Example: http://neon-local:5432/sql
NEON_LOCAL_SQL_ENDPOINT=<optional_neon_local_sql_endpoint>
